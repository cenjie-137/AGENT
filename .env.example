# 大模型 API 配置（必填）
# 支持 deepseek / openai / spark
LLM_PROVIDER=deepseek
LLM_API_KEY=your_deepseek_api_key_here
LLM_API_BASE=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 讯飞语音听写（流式版）配置 - 适合实时短音频（1分钟内）
XFYUN_ASR_APP_ID=your_xfyun_app_id
XFYUN_ASR_API_KEY=your_xfyun_api_key
XFYUN_ASR_API_SECRET=your_xfyun_api_secret

# 讯飞录音文件转写（长音频）配置 - 适合会议录音（最长5小时）
XFYUN_LFASR_APP_ID=your_xfyun_app_id
XFYUN_LFASR_SECRET_KEY=your_xfyun_secret_key

# 讯飞星火大模型配置（可选）
SPARK_APP_ID=
SPARK_API_SECRET=
SPARK_API_KEY=
SPARK_DOMAIN=generalv4

# 行业配置（可选，默认 education）
# 可选值：education, healthcare, manufacturing, finance
INDUSTRY=education